   "source": [
    "### 표준 입출력\n",
    "\n",
    "- 표준 입력 : 키보드 => input()\n",
    "- 표준 출력 : 모니터 => print()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "5b554850",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "숫자를 입력하세요\n"
     ]
    }
   ],
   "source": [
    "num = input(\"숫자 입력\")\n",
    "\n",
    "# type(num)\n",
    "# 사용자에게 숫자를 입력받은 후 +10 한 결과 출력\n",
    "# try ~ except\n",
    "if num.isdigit():\n",
    "    num = int(num) + 10\n",
    "    print(num)\n",
    "else:\n",
    "    print(\"숫자를 입력하세요\")"
   ]
  }
 ],
